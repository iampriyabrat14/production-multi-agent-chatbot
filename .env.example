# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Vector DB (Pinecone) ───────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=chatbot-index

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Local development (matches docker-compose.yml)
POSTGRES_URL=postgresql://chatbot_user:chatbot_pass@localhost:5432/chatbot
# AWS RDS (fill in after Terraform deploy)
# POSTGRES_URL=postgresql://chatbot_user:chatbot_pass@<rds-endpoint>:5432/chatbot

# ── Cache + Queue (Redis) ──────────────────────────────────────────────────────
# Local development (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379
# AWS ElastiCache (fill in after Terraform deploy)
# REDIS_URL=redis://<elasticache-endpoint>:6379

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ── Rate Limiting ──────────────────────────────────────────────────────────────
CHAT_RATE_LIMIT=60/minute

# ── Currency API (ExchangeRate-API) ───────────────────────────────────────────
# Get free key at: https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=

# ── CSV Data Directory ─────────────────────────────────────────────────────────
CSV_DIR=data/csv_files

# ── Observability (LangSmith) ──────────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=production-chatbot
LANGCHAIN_TRACING_V2=true

# ── Evaluation (RAGAS) ────────────────────────────────────────────────────────
RAGAS_FAITHFULNESS_THRESHOLD=0.85
RAGAS_RELEVANCY_THRESHOLD=0.80
RAGAS_RECALL_THRESHOLD=0.75
RAGAS_PRECISION_THRESHOLD=0.75

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ECR_REPOSITORY=chatbot-api
AWS_ECS_CLUSTER=chatbot-cluster
AWS_ECS_SERVICE_API=chatbot-api-service
AWS_ECS_SERVICE_UI=chatbot-ui-service

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_IMAGE_TAG=latest

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000

# ── Streamlit (UI) ────────────────────────────────────────────────────────────
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
